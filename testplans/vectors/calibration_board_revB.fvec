; FBC Vector File - Calibration Board Rev B
; Human-readable format, compile with: fbc-vec compile calibration_board_revB.fvec -o calibration_board_revB.fbc
;
; Format: Each line is a 160-bit vector (40 hex chars)
; Pins: [159:128]=Bank35(Fast) [127:96]=Bank34 [95:48]=Bank33 [47:0]=Bank13

; ============================================================================
; TEST 1: All Zeros (Baseline)
; ============================================================================
.label TEST_ALL_ZEROS
.repeat 100
00000000000000000000000000000000000000000000000000

; ============================================================================
; TEST 2: All Ones (Full Drive)
; ============================================================================
.label TEST_ALL_ONES
.repeat 100
FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF

; ============================================================================
; TEST 3: Checkerboard Pattern (Alternating)
; ============================================================================
.label TEST_CHECKERBOARD_A
.repeat 50
AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

.label TEST_CHECKERBOARD_B
.repeat 50
55555555555555555555555555555555555555555555555555

