; ============================================================================
; TEST 8: VOUT LED Test (through load resistors)
; Output pattern to toggle VOUT1-8 pins and verify via LED current
; ============================================================================
.label VOUT_LED_TEST
; All VOUTs off
00000000000000000000000000000000000000000000000000
.repeat 10
; VOUT1 on
00000000000000000000000000000000000000000000000001
.repeat 10
; VOUT2 on
00000000000000000000000000000000000000000000000002
.repeat 10
; VOUT3 on
00000000000000000000000000000000000000000000000004
.repeat 10
; VOUT4 on
00000000000000000000000000000000000000000000000008
