# FBC Bring-Up Test Vector - Fast Pins Only
# Targets gpio[128:159] (Bank 35, 1-cycle latency)
# Safe to run with just 12V/3A - no DUT power needed
#
# Compile: fbc-vec compile bringup_fast_pins.fvec -o bringup_fast_pins.fbc -v

CLOCK 5000000

# Pin configuration: fast pins 128-159 as outputs
PIN 128-159 OUTPUT
# BIM pins 0-127 as inputs (monitor only, no drive)
PIN 0-127 INPUT

# ============================================================
# TEST 1: All zeros baseline (10 vectors)
# ============================================================
LABEL all_zeros
ZERO REPEAT 10

# ============================================================
# TEST 2: All ones (10 vectors)
# ============================================================
LABEL all_ones
ONES REPEAT 10

# ============================================================
# TEST 3: Walking one on fast pins (32 vectors)
# Each vector has exactly one fast pin high
# Pin 128 = bit 128 of 160-bit vector
# ============================================================
LABEL walk_one_fast

# Hex format: 160 bits = 40 hex chars
# Bits [159:128] are the leftmost 8 hex chars
# Pin 128 = bit 128 = byte 16 bit 0 = hex char position 39 from left...
# Actually: 160-bit vector laid out as [159:0], hex is MSB first
# Pin 128 is bit 128. In 40-char hex: char index (159-128)/4 = 7 from left, bit (128%4)=0
# Byte 3 (from MSB) has bits [135:128]. Pin 128 = LSB of that byte = 0x01 at position 7

# Easier: use binary format for precision
# 160 bits: positions [159] ... [128] ... [0]
# We want pin 128 high = bit position 128

# Pin 128 (bit 128)
0x0000000100000000000000000000000000000000
# Pin 129
0x0000000200000000000000000000000000000000
# Pin 130
0x0000000400000000000000000000000000000000
# Pin 131
0x0000000800000000000000000000000000000000
# Pin 132
0x0000001000000000000000000000000000000000
# Pin 133
0x0000002000000000000000000000000000000000
# Pin 134
0x0000004000000000000000000000000000000000
# Pin 135
0x0000008000000000000000000000000000000000
# Pin 136
0x0000010000000000000000000000000000000000
# Pin 137
0x0000020000000000000000000000000000000000
# Pin 138
0x0000040000000000000000000000000000000000
# Pin 139
0x0000080000000000000000000000000000000000
# Pin 140
0x0000100000000000000000000000000000000000
# Pin 141
0x0000200000000000000000000000000000000000
# Pin 142
0x0000400000000000000000000000000000000000
# Pin 143
0x0000800000000000000000000000000000000000
# Pin 144
0x0001000000000000000000000000000000000000
# Pin 145
0x0002000000000000000000000000000000000000
# Pin 146
0x0004000000000000000000000000000000000000
# Pin 147
0x0008000000000000000000000000000000000000
# Pin 148
0x0010000000000000000000000000000000000000
# Pin 149
0x0020000000000000000000000000000000000000
# Pin 150
0x0040000000000000000000000000000000000000
# Pin 151
0x0080000000000000000000000000000000000000
# Pin 152
0x0100000000000000000000000000000000000000
# Pin 153
0x0200000000000000000000000000000000000000
# Pin 154
0x0400000000000000000000000000000000000000
# Pin 155
0x0800000000000000000000000000000000000000
# Pin 156
0x1000000000000000000000000000000000000000
# Pin 157
0x2000000000000000000000000000000000000000
# Pin 158
0x4000000000000000000000000000000000000000
# Pin 159
0x8000000000000000000000000000000000000000

# ============================================================
# TEST 4: Checkerboard on fast pins (20 vectors)
# ============================================================
LABEL checkerboard
0xAAAAAAAA00000000000000000000000000000000 REPEAT 10
0x5555555500000000000000000000000000000000 REPEAT 10

# ============================================================
# TEST 5: All fast pins toggle (20 vectors)
# ============================================================
LABEL toggle_all_fast
0xFFFFFFFF00000000000000000000000000000000 REPEAT 10
ZERO REPEAT 10

# ============================================================
# TEST 6: Return to zeros (safe state)
# ============================================================
LABEL safe_off
ZERO REPEAT 10
